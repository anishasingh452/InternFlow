<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mentor Dashboard"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Track ownership, progress, and blockers at a glance."
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp"
            android:textSize="16sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:columnCount="2"
            android:rowCount="2">

            <include
                android:id="@+id/totalCard"
                layout="@layout/view_stat_card" />

            <include
                android:id="@+id/progressCard"
                layout="@layout/view_stat_card" />

            <include
                android:id="@+id/completedCard"
                layout="@layout/view_stat_card" />

            <include
                android:id="@+id/attentionCard"
                layout="@layout/view_stat_card" />
        </GridLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#FECACA"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Needs Attention"
                    android:textColor="@color/attention"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/attentionSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/dashboard_attention_clear"
                    android:textColor="@color/text_primary"
                    android:lineSpacingExtra="2dp"
                    android:textSize="17sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addTaskButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="30dp"
            android:text="Add Task"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewTasksButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="View All Tasks"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="18dp" />
    </LinearLayout>
</ScrollView>

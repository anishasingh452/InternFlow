<resources>
    <style name="Theme.InternFlow" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorSecondary">@color/status_in_progress</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/brand_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/brand_light</item>
        <item name="android:navigationBarColor">@color/brand_light</item>
    </style>

    <style name="Widget.InternFlow.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="shapeAppearance">@style/ShapeAppearance.InternFlow.Medium</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="ShapeAppearance.InternFlow.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>
